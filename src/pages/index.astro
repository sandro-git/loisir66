---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { sanityClient, urlForImage } from '../lib/sanity.js';

const activites: any[] = sanityClient
  ? await sanityClient.fetch(
      `*[_type == "adherent"] | order(nom asc) { nom, "slug": slug.current, type, publics, saison, description, ville, image }`
    ).catch(() => [])
  : [];

const types   = [...new Set(activites.map((a) => a.type).filter(Boolean))].sort() as string[];
const publics = [...new Set(activites.flatMap((a) => a.publics ?? []).filter(Boolean))] as string[];
const saisons = [...new Set(activites.map((a) => a.saison).filter(Boolean))] as string[];
const villes  = [...new Set(activites.map((a) => a.ville).filter(Boolean))].sort() as string[];
const total   = activites.length;

function toTitleCase(str: string): string {
  if (!str) return str;
  return str.toLowerCase().replace(/(?:^|[\s\-\/])\S/g, (c) => c.toUpperCase());
}

const typeEmoji: Record<string, string> = { 'Outdoor': '🌿', 'Indoor': '🏠' };
const saisonEmoji: Record<string, string> = { 'Été': '☀️', 'Hiver': '❄️', 'Toute saison': '🗓️' };

function getFallbackImg(nom: string, type: string): string {
  const n = nom.toLowerCase();
  const q = '?auto=format&fit=crop&w=480&h=200&q=80';
  const u = 'https://images.unsplash.com/photo-';
  const checks: [string[], string][] = [
    [['ski','neige','alpin','romeu','2000','snowboard','hiver','glisse'],       '1551698618-1dfe5d97d256'],
    [['plongée','diving','aqua','snorkel','corail'],                            '1544551763-46a013bb70d5'],
    [['nautique','voile','kayak','canoe','canoë','bateau','régate','surf'],      '1530053969600-caed2596d242'],
    [['escalade','grimpe','via ferrata','bloc','varappe'],                      '1522163182402-834f871fd851'],
    [['vélo','vtt','cyclisme','bmx','bike','cycle'],                            '1558618666-fcd25c85cd64'],
    [['cheval','équi','horse','poney','ranch','polo'],                          '1553284965-83fd3e82fa5a'],
    [['ferme','élevage','âne','poule','animaux de la'],                         '1500595046743-cd271d694d30'],
    [['tortue','reptile','terrarium'],                                          '1548550804-f38e88d0e2f6'],
    [['jardin','botanique','fleur','ariane','potager','plante'],                '1416879595882-3373a0480b5b'],
    [['vin','wine','dégustation','cave','vigne','vendange'],                    '1506377247377-2a5b3b417ebb'],
    [['children','paradise','enfant','kids','ludique','jeux','trampoline'],     '1566127444979-2707e8df55bb'],
    [['yoga','pilates','méditation','zen','sophrologie','bien-être'],           '1544367567-0f2fcb009e0b'],
    [['cuisine','gastro','cook','chef','pâtisserie','atelier culinaire'],       '1556909114-f6e7ad7d3136'],
    [['randonnée','trek','rando','hiking','marche nordique'],                   '1483728642387-6c3bdd6c93e5'],
    [['parc','acrobat','accro','tyrolienne','arbre','forêt','aventure'],        '1505765050516-f72dc741e925'],
    [['laser','paintball','airsoft','escape','room'],                           '1612170153604-b7f7af55e94b'],
    [['vr','réalité virtuelle','virtuel'],                                      '1617802690658-1173a812650d'],
    [['karting','kart','circuit','moto'],                                       '1568772585407-9f3a8f8b4b4a'],
    [['golf'],                                                                  '1537175467824-4c4e817c1bbe'],
    [['tennis','padel','squash','badminton'],                                   '1554068865-24cecd4e34b8'],
    [['musique','chant','concert','orchestre'],                                 '1511671001-8673-4aff-aea9-cd955b631f6b'],
    [['photo','photographie'],                                                  '1516035069371-29a1b244cc32'],
    [['musée','expo','patrimoine','château','visite'],                          '1554907984-15263bfd63bd'],
    [['théâtre','spectacle','danse','ballet'],                                  '1507608168822-ecf2f7f7e8fd'],
    [['pêche','fishing'],                                                       '1548438294-1ad5d5f4f063'],
    [['spa','massage','bain','détente','thermal'],                              '1540555700478-4be289fbecef'],
    [['peinture','dessin','art','poterie','céramique'],                         '1513364776144-60967b0f800f'],
  ];
  for (const [keywords, id] of checks) {
    if (keywords.some(k => n.includes(k))) return u + id + q;
  }
  if (type === 'Indoor') return u + '1571019613454-1cb2f99b2d8b' + q;
  return u + '1506905925346-21bda4d32df4' + q;
}
---

<Layout title="Loisirs 66 — Trouver une activité">

  <!-- Barre de recherche sticky (apparaît quand le hero sort du viewport) -->
  <div id="sticky-bar" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md shadow-md -translate-y-full transition-transform duration-300 pointer-events-none">
    <div class="max-w-6xl mx-auto px-4 pt-3 pb-2">
      <!-- Ligne recherche + géo -->
      <div class="flex gap-2 mb-2">
        <input
          id="sticky-search-input"
          type="search"
          placeholder="Escalade, karting, plongée..."
          autocomplete="off"
          class="flex-1 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 text-gray-900 placeholder-gray-400 outline-none focus:border-orange-300 text-sm"
        />
        <button
          id="sticky-btn-geo"
          title="Activités proches de moi"
          class="flex-shrink-0 bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-gray-500 hover:text-orange-500 transition-colors outline-none"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="3"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
            <circle cx="12" cy="12" r="8" stroke-dasharray="4 2"/>
          </svg>
        </button>
      </div>
      <!-- Chips de filtre -->
      <div class="flex flex-wrap sm:flex-nowrap gap-2 items-center pb-1 max-h-[72px] overflow-hidden sm:max-h-none sm:overflow-x-auto">
        {types.map((t) => (
          <button class="chip flex-shrink-0" data-filter="type" data-value={t.toLowerCase()}>
            {typeEmoji[t] ?? ''} {t}
          </button>
        ))}
        <div class="w-px h-5 bg-gray-200 mx-0.5 flex-shrink-0"></div>
        {publics.map((p) => (
          <button class="chip flex-shrink-0" data-filter="public" data-value={p.toLowerCase()}>{p}</button>
        ))}
        <div class="w-px h-5 bg-gray-200 mx-0.5 flex-shrink-0"></div>
        {saisons.map((s) => (
          <button class="chip flex-shrink-0" data-filter="saison" data-value={s.toLowerCase()}>
            {saisonEmoji[s] ?? ''} {s}
          </button>
        ))}
        {villes.length > 0 && (
          <>
            <div class="w-px h-5 bg-gray-200 mx-0.5 flex-shrink-0"></div>
            {villes.map((v) => (
              <button class="chip flex-shrink-0" data-filter="ville" data-value={v.toLowerCase()}>
                📍 {toTitleCase(v)}
              </button>
            ))}
          </>
        )}
      </div>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 py-8">

    <!-- Logo -->
    <div class="flex justify-center mb-6">
      <img src="/logo-aplpo.avif" alt="APLPO — Loisirs 66" class="w-1/2 sm:w-auto sm:h-16" loading="eager" fetchpriority="high" />
    </div>

    <!-- Hero -->
    <div data-hero class="relative rounded-3xl overflow-hidden mb-6 bg-gradient-to-br from-orange-400 via-rose-300 to-sky-400 p-8 md:p-12">
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-white/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-white/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="relative z-10">
        <p class="text-white/80 text-xs uppercase tracking-widest mb-3 text-center">Pyrénées-Orientales</p>
        <h1 class="text-white text-3xl md:text-4xl font-bold mb-2 leading-tight text-center">
          Trouvez une activité
        </h1>
        <p class="text-white/75 mb-7 text-sm text-center">{total} activités à découvrir dans le 66</p>
        <div class="flex gap-2">
          <input
            id="search-input"
            type="search"
            placeholder="Escalade, karting, plongée..."
            autocomplete="off"
            class="flex-1 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 outline-none focus:bg-white transition-colors"
          />
          <button
            id="btn-geolocate"
            title="Activités proches de moi"
            class="flex-shrink-0 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 text-gray-500 hover:text-orange-500 hover:bg-white transition-colors outline-none"
          >
            <svg id="geo-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
              <circle cx="12" cy="12" r="8" stroke-dasharray="4 2"/>
            </svg>
            <svg id="geo-spinner" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2a10 10 0 0 1 10 10"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Filtres en chips — cachés sur mobile -->
    <div class="hidden sm:flex flex-wrap gap-2 mb-5 items-center">
      {types.map((t) => (
        <button class="chip" data-filter="type" data-value={t.toLowerCase()}>
          {typeEmoji[t] ?? ''} {t}
        </button>
      ))}
      <div class="w-px h-5 bg-gray-200 mx-1"></div>
      {publics.map((p) => (
        <button class="chip" data-filter="public" data-value={p.toLowerCase()}>{p}</button>
      ))}
      <div class="w-px h-5 bg-gray-200 mx-1"></div>
      {saisons.map((s) => (
        <button class="chip" data-filter="saison" data-value={s.toLowerCase()}>
          {saisonEmoji[s] ?? ''} {s}
        </button>
      ))}
      {villes.length > 0 && (
        <>
          <div class="w-px h-5 bg-gray-200 mx-1"></div>
          {villes.map((v) => (
            <button class="chip" data-filter="ville" data-value={v.toLowerCase()}>
              📍 {toTitleCase(v)}
            </button>
          ))}
        </>
      )}
    </div>

    <!-- Compteur -->
    <p id="count" class="text-gray-400 text-sm mb-5">
      {total} activité{total > 1 ? 's' : ''} trouvée{total > 1 ? 's' : ''}
    </p>

    <!-- Grille de cartes -->
    <div id="cards-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {activites?.map((a, i) => {
        const imgUrl = a.image ? urlForImage(a.image)?.width(480).height(200).fit('crop').url() : null;
        const eager = i === 0;
        return (
          <a
            href={a.slug ? `/loisirs66/${a.slug}` : '#'}
            class="activity-card group bg-white border border-gray-100 shadow-sm rounded-2xl overflow-hidden flex flex-col hover:shadow-md hover:-translate-y-0.5 transition-all no-underline"
            data-nom={(a.nom ?? '').toLowerCase()}
            data-description={(a.description ?? '').toLowerCase()}
            data-type={(a.type ?? '').toLowerCase()}
            data-public={(a.publics ?? []).join(',').toLowerCase()}
            data-saison={(a.saison ?? '').toLowerCase()}
            data-ville={(a.ville ?? '').toLowerCase()}
          >
            <div class="h-36 overflow-hidden flex-shrink-0 relative">
              {imgUrl ? (
                <Image
                  src={imgUrl}
                  alt={a.nom ?? ''}
                  width={480}
                  height={200}
                  loading={eager ? 'eager' : 'lazy'}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              ) : (
                <>
                  <Image
                    src={getFallbackImg(a.nom ?? '', a.type ?? '')}
                    alt={a.nom ?? ''}
                    width={480}
                    height={200}
                    loading={eager ? 'eager' : 'lazy'}
                    class="fallback-img w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                  <div class={`fallback-gradient hidden absolute inset-0 w-full h-full flex items-center justify-center ${
                    a.type === 'Outdoor'
                      ? 'bg-gradient-to-br from-green-300 via-emerald-400 to-teal-500'
                      : 'bg-gradient-to-br from-sky-300 via-blue-400 to-indigo-500'
                  }`}>
                    <span class="text-white/25 text-7xl font-black select-none">
                      {(a.nom ?? '').charAt(0)}
                    </span>
                  </div>
                </>
              )}
            </div>
            <div class="p-5 flex flex-col gap-2 flex-1">
              <div class="flex gap-1.5 flex-wrap">
                {a.type && (
                  <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${
                    a.type === 'Outdoor' ? 'bg-green-100 text-green-700' : 'bg-sky-100 text-sky-700'
                  }`}>
                    {typeEmoji[a.type] ?? ''} {a.type}
                  </span>
                )}
                {(a.publics ?? []).map((p: string) => (
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gray-100 text-gray-500">{p}</span>
                ))}
              </div>
              <h2 class="text-base font-bold text-gray-900 leading-snug">{toTitleCase(a.nom ?? '')}</h2>
              {a.description && (
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{a.description}</p>
              )}
              {a.ville && (
                <p class="text-gray-400 text-xs mt-auto flex items-center gap-1">
                  <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {toTitleCase(a.ville)}
                  <span class="distance-badge hidden text-orange-500 font-medium"></span>
                </p>
              )}
            </div>
          </a>
        );
      })}
    </div>

  </main>
</Layout>

<style is:global>
  .chip {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    background: #f3f4f6;
    color: #6b7280;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    border: 1.5px solid transparent;
  }
  .chip:hover { background: #e5e7eb; color: #374151; }
  .chip.active { background: #fff7ed; color: #ea580c; border-color: #fdba74; }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const cards       = document.querySelectorAll<HTMLElement>('.activity-card');
  const countEl     = document.getElementById('count');
  const btnGeo      = document.getElementById('btn-geolocate') as HTMLButtonElement;
  const geoIcon     = document.getElementById('geo-icon') as SVGElement;
  const geoSpinner  = document.getElementById('geo-spinner') as SVGElement;
  const grid        = document.getElementById('cards-grid') as HTMLElement;

  const filters: Record<string, string> = { type: '', public: '', saison: '', ville: '' };

  function applyFilters() {
    const query = searchInput.value.toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const matches =
        (!query          || (card.dataset.nom ?? '').includes(query) || (card.dataset.description ?? '').includes(query)) &&
        (!filters.type   || (card.dataset.type ?? '') === filters.type) &&
        (!filters.public || (card.dataset.public ?? '').includes(filters.public)) &&
        (!filters.saison || (card.dataset.saison ?? '') === filters.saison) &&
        (!filters.ville  || (card.dataset.ville ?? '') === filters.ville);
      card.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });
    if (countEl) countEl.textContent = `${visible} activité${visible > 1 ? 's' : ''} trouvée${visible > 1 ? 's' : ''}`;
  }

  document.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter!;
      const value  = chip.dataset.value!;
      filters[filter] = filters[filter] === value ? '' : value;
      document.querySelectorAll<HTMLButtonElement>(`.chip[data-filter="${filter}"]`).forEach((c) => {
        c.classList.toggle('active', c.dataset.value === filters[filter]);
      });
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', applyFilters);

  function haversine(lat1: number, lon1: number, lat2: number, lon2: number): number {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  const geocodeCache: Record<string, { lat: number; lng: number } | null> = {};

  async function geocodeVille(ville: string): Promise<{ lat: number; lng: number } | null> {
    if (ville in geocodeCache) return geocodeCache[ville];
    try {
      const res = await fetch(
        `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(ville + ', Pyrénées-Orientales, France')}&format=json&limit=1&addressdetails=0`,
        { headers: { 'Accept-Language': 'fr', 'User-Agent': 'loisirs66-app/1.0' } }
      );
      const data = await res.json();
      const result = data[0] ? { lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon) } : null;
      geocodeCache[ville] = result;
      await new Promise((r) => setTimeout(r, 1100));
      return result;
    } catch (e) {
      console.error('Geocode error:', ville, e);
      geocodeCache[ville] = null;
      return null;
    }
  }

  async function geocodeSequential(villes: string[]) { for (const v of villes) await geocodeVille(v); }

  function setGeoLoading(loading: boolean) {
    btnGeo.disabled = loading;
    geoIcon.classList.toggle('hidden', loading);
    geoSpinner.classList.toggle('hidden', !loading);
  }

  function resetGeo() {
    document.querySelectorAll<HTMLElement>('.distance-badge').forEach((el) => { el.textContent = ''; el.classList.add('hidden'); });
    [...cards].sort((a, b) => (a.dataset.nom ?? '').localeCompare(b.dataset.nom ?? '')).forEach((c) => grid.appendChild(c));
    btnGeo.classList.remove('text-orange-500');
    btnGeo.classList.add('text-gray-500');
  }

  let geoActive = false;

  btnGeo?.addEventListener('click', async () => {
    if (geoActive) { geoActive = false; resetGeo(); return; }
    if (!navigator.geolocation) { alert("La géolocalisation n'est pas supportée."); return; }
    setGeoLoading(true);
    navigator.geolocation.getCurrentPosition(
      async (pos) => {
        const { latitude: userLat, longitude: userLng } = pos.coords;
        const uniqueVilles = new Set<string>();
        cards.forEach((c) => { if (c.dataset.ville) uniqueVilles.add(c.dataset.ville); });
        await geocodeSequential([...uniqueVilles]);
        cards.forEach((card) => {
          const coords = geocodeCache[card.dataset.ville ?? ''];
          if (coords) {
            const dist = haversine(userLat, userLng, coords.lat, coords.lng);
            card.dataset.distanceKm = dist.toFixed(1);
            const badge = card.querySelector<HTMLElement>('.distance-badge');
            if (badge) { badge.textContent = `· ${dist < 1 ? '< 1' : Math.round(dist)} km`; badge.classList.remove('hidden'); }
          } else { card.dataset.distanceKm = '99999'; }
        });
        [...cards].sort((a, b) => parseFloat(a.dataset.distanceKm ?? '99999') - parseFloat(b.dataset.distanceKm ?? '99999')).forEach((c) => grid.appendChild(c));
        geoActive = true;
        btnGeo.classList.remove('text-gray-500');
        btnGeo.classList.add('text-orange-500');
        setGeoLoading(false);
      },
      (err) => { setGeoLoading(false); if (err.code !== err.PERMISSION_DENIED) alert("Impossible d'obtenir votre position."); },
      { timeout: 10000 }
    );
  });

  // Sticky search bar
  const stickyBar       = document.getElementById('sticky-bar') as HTMLElement;
  const stickyInput     = document.getElementById('sticky-search-input') as HTMLInputElement;
  const stickyBtnGeo    = document.getElementById('sticky-btn-geo') as HTMLButtonElement;
  const hero            = document.querySelector('[data-hero]') as HTMLElement;

  const heroObserver = new IntersectionObserver(
    ([entry]) => {
      const hidden = entry.isIntersecting;
      stickyBar.classList.toggle('-translate-y-full', hidden);
      stickyBar.classList.toggle('pointer-events-none', hidden);
    },
    { threshold: 0 }
  );
  if (hero) heroObserver.observe(hero);

  stickyInput?.addEventListener('input', () => {
    if (searchInput) searchInput.value = stickyInput.value;
    applyFilters();
  });
  searchInput?.addEventListener('input', () => {
    if (stickyInput) stickyInput.value = searchInput.value;
  });
  stickyBtnGeo?.addEventListener('click', () => btnGeo?.click());

  // Fallback gradient si l'image Unsplash ne charge pas
  document.querySelectorAll<HTMLImageElement>('.fallback-img').forEach(img => {
    img.addEventListener('error', function () {
      this.classList.add('hidden');
      (this.nextElementSibling as HTMLElement)?.classList.remove('hidden');
    });
  });
</script>
