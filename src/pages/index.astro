---
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlForImage } from '../lib/sanity.js';

const activites: any[] = sanityClient
  ? await sanityClient.fetch(
      `*[_type == "adherent"] | order(nom asc) { nom, "slug": slug.current, type, publics, saison, description, ville, image }`
    ).catch(() => [])
  : [];

const types   = [...new Set(activites.map((a) => a.type).filter(Boolean))].sort() as string[];
const publics = [...new Set(activites.flatMap((a) => a.publics ?? []).filter(Boolean))] as string[];
const saisons = [...new Set(activites.map((a) => a.saison).filter(Boolean))] as string[];
const villes  = [...new Set(activites.map((a) => a.ville).filter(Boolean))].sort() as string[];
const total   = activites.length;

function toTitleCase(str: string): string {
  if (!str) return str;
  return str.toLowerCase().replace(/(?:^|[\s\-\/])\S/g, (c) => c.toUpperCase());
}

const typeEmoji: Record<string, string> = { 'Outdoor': '🌿', 'Indoor': '🏠' };
const saisonEmoji: Record<string, string> = { 'Été': '☀️', 'Hiver': '❄️', 'Toute saison': '🗓️' };
---

<Layout title="Loisirs 66 — Trouver une activité">
  <main class="max-w-6xl mx-auto px-4 py-8">

    <!-- Logo -->
    <div class="flex justify-center mb-6">
      <img src="/logo-aplpo.avif" alt="APLPO — Loisirs 66" class="h-16 w-auto" />
    </div>

    <!-- Hero -->
    <div class="relative rounded-3xl overflow-hidden mb-6 bg-gradient-to-br from-orange-400 via-rose-300 to-sky-400 p-8 md:p-12">
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-white/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-white/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="relative z-10">
        <p class="text-white/80 text-xs uppercase tracking-widest mb-3">Pyrénées-Orientales</p>
        <h1 class="text-white text-3xl md:text-4xl font-bold mb-2 leading-tight">
          Trouvez votre<br/>prochaine aventure
        </h1>
        <p class="text-white/75 mb-7 text-sm">{total} activités à découvrir dans le 66</p>
        <div class="flex gap-2">
          <input
            id="search-input"
            type="search"
            placeholder="Escalade, karting, plongée..."
            autocomplete="off"
            class="flex-1 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 outline-none focus:bg-white transition-colors"
          />
          <button
            id="btn-geolocate"
            title="Activités proches de moi"
            class="flex-shrink-0 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 text-gray-500 hover:text-orange-500 hover:bg-white transition-colors outline-none"
          >
            <svg id="geo-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
              <circle cx="12" cy="12" r="8" stroke-dasharray="4 2"/>
            </svg>
            <svg id="geo-spinner" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2a10 10 0 0 1 10 10"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Filtres en chips — cachés sur mobile -->
    <div class="hidden sm:flex flex-wrap gap-2 mb-5 items-center">
      {types.map((t) => (
        <button class="chip" data-filter="type" data-value={t.toLowerCase()}>
          {typeEmoji[t] ?? ''} {t}
        </button>
      ))}
      <div class="w-px h-5 bg-gray-200 mx-1"></div>
      {publics.map((p) => (
        <button class="chip" data-filter="public" data-value={p.toLowerCase()}>{p}</button>
      ))}
      <div class="w-px h-5 bg-gray-200 mx-1"></div>
      {saisons.map((s) => (
        <button class="chip" data-filter="saison" data-value={s.toLowerCase()}>
          {saisonEmoji[s] ?? ''} {s}
        </button>
      ))}
      {villes.length > 0 && (
        <>
          <div class="w-px h-5 bg-gray-200 mx-1"></div>
          {villes.map((v) => (
            <button class="chip" data-filter="ville" data-value={v.toLowerCase()}>
              📍 {toTitleCase(v)}
            </button>
          ))}
        </>
      )}
    </div>

    <!-- Compteur -->
    <p id="count" class="text-gray-400 text-sm mb-5">
      {total} activité{total > 1 ? 's' : ''} trouvée{total > 1 ? 's' : ''}
    </p>

    <!-- Grille de cartes -->
    <div id="cards-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {activites?.map((a) => {
        const imgUrl = a.image ? urlForImage(a.image)?.width(480).height(200).fit('crop').url() : null;
        return (
          <a
            href={a.slug ? `/loisirs66/${a.slug}` : '#'}
            class="activity-card group bg-white border border-gray-100 shadow-sm rounded-2xl overflow-hidden flex flex-col hover:shadow-md hover:-translate-y-0.5 transition-all no-underline"
            data-nom={(a.nom ?? '').toLowerCase()}
            data-description={(a.description ?? '').toLowerCase()}
            data-type={(a.type ?? '').toLowerCase()}
            data-public={(a.publics ?? []).join(',').toLowerCase()}
            data-saison={(a.saison ?? '').toLowerCase()}
            data-ville={(a.ville ?? '').toLowerCase()}
          >
            <div class="h-36 overflow-hidden flex-shrink-0">
              {imgUrl ? (
                <img
                  src={imgUrl}
                  alt={a.nom}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              ) : (
                <div class={`w-full h-full flex items-center justify-center ${
                  a.type === 'Outdoor'
                    ? 'bg-gradient-to-br from-green-300 via-emerald-400 to-teal-500'
                    : 'bg-gradient-to-br from-sky-300 via-blue-400 to-indigo-500'
                }`}>
                  <span class="text-white/25 text-7xl font-black select-none">
                    {(a.nom ?? '').charAt(0)}
                  </span>
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col gap-2 flex-1">
              <div class="flex gap-1.5 flex-wrap">
                {a.type && (
                  <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${
                    a.type === 'Outdoor' ? 'bg-green-100 text-green-700' : 'bg-sky-100 text-sky-700'
                  }`}>
                    {typeEmoji[a.type] ?? ''} {a.type}
                  </span>
                )}
                {(a.publics ?? []).map((p: string) => (
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gray-100 text-gray-500">{p}</span>
                ))}
              </div>
              <h2 class="text-base font-bold text-gray-900 leading-snug">{toTitleCase(a.nom ?? '')}</h2>
              {a.description && (
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{a.description}</p>
              )}
              {a.ville && (
                <p class="text-gray-400 text-xs mt-auto flex items-center gap-1">
                  <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {toTitleCase(a.ville)}
                  <span class="distance-badge hidden text-orange-500 font-medium"></span>
                </p>
              )}
            </div>
          </a>
        );
      })}
    </div>

  </main>
</Layout>

<style is:global>
  .chip {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    background: #f3f4f6;
    color: #6b7280;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    border: 1.5px solid transparent;
  }
  .chip:hover { background: #e5e7eb; color: #374151; }
  .chip.active { background: #fff7ed; color: #ea580c; border-color: #fdba74; }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const cards       = document.querySelectorAll<HTMLElement>('.activity-card');
  const countEl     = document.getElementById('count');
  const btnGeo      = document.getElementById('btn-geolocate') as HTMLButtonElement;
  const geoIcon     = document.getElementById('geo-icon') as SVGElement;
  const geoSpinner  = document.getElementById('geo-spinner') as SVGElement;
  const grid        = document.getElementById('cards-grid') as HTMLElement;

  const filters: Record<string, string> = { type: '', public: '', saison: '', ville: '' };

  function applyFilters() {
    const query = searchInput.value.toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const matches =
        (!query          || (card.dataset.nom ?? '').includes(query) || (card.dataset.description ?? '').includes(query)) &&
        (!filters.type   || (card.dataset.type ?? '') === filters.type) &&
        (!filters.public || (card.dataset.public ?? '').includes(filters.public)) &&
        (!filters.saison || (card.dataset.saison ?? '') === filters.saison) &&
        (!filters.ville  || (card.dataset.ville ?? '') === filters.ville);
      card.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });
    if (countEl) countEl.textContent = `${visible} activité${visible > 1 ? 's' : ''} trouvée${visible > 1 ? 's' : ''}`;
  }

  document.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter!;
      const value  = chip.dataset.value!;
      filters[filter] = filters[filter] === value ? '' : value;
      document.querySelectorAll<HTMLButtonElement>(`.chip[data-filter="${filter}"]`).forEach((c) => {
        c.classList.toggle('active', c.dataset.value === filters[filter]);
      });
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', applyFilters);

  function haversine(lat1: number, lon1: number, lat2: number, lon2: number): number {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  const geocodeCache: Record<string, { lat: number; lng: number } | null> = {};

  async function geocodeVille(ville: string): Promise<{ lat: number; lng: number } | null> {
    if (ville in geocodeCache) return geocodeCache[ville];
    try {
      const res = await fetch(
        `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(ville + ', Pyrénées-Orientales, France')}&format=json&limit=1&addressdetails=0`,
        { headers: { 'Accept-Language': 'fr', 'User-Agent': 'loisirs66-app/1.0' } }
      );
      const data = await res.json();
      const result = data[0] ? { lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon) } : null;
      geocodeCache[ville] = result;
      await new Promise((r) => setTimeout(r, 1100));
      return result;
    } catch (e) {
      console.error('Geocode error:', ville, e);
      geocodeCache[ville] = null;
      return null;
    }
  }

  async function geocodeSequential(villes: string[]) { for (const v of villes) await geocodeVille(v); }

  function setGeoLoading(loading: boolean) {
    btnGeo.disabled = loading;
    geoIcon.classList.toggle('hidden', loading);
    geoSpinner.classList.toggle('hidden', !loading);
  }

  function resetGeo() {
    document.querySelectorAll<HTMLElement>('.distance-badge').forEach((el) => { el.textContent = ''; el.classList.add('hidden'); });
    [...cards].sort((a, b) => (a.dataset.nom ?? '').localeCompare(b.dataset.nom ?? '')).forEach((c) => grid.appendChild(c));
    btnGeo.classList.remove('text-orange-500');
    btnGeo.classList.add('text-gray-500');
  }

  let geoActive = false;

  btnGeo?.addEventListener('click', async () => {
    if (geoActive) { geoActive = false; resetGeo(); return; }
    if (!navigator.geolocation) { alert("La géolocalisation n'est pas supportée."); return; }
    setGeoLoading(true);
    navigator.geolocation.getCurrentPosition(
      async (pos) => {
        const { latitude: userLat, longitude: userLng } = pos.coords;
        const uniqueVilles = new Set<string>();
        cards.forEach((c) => { if (c.dataset.ville) uniqueVilles.add(c.dataset.ville); });
        await geocodeSequential([...uniqueVilles]);
        cards.forEach((card) => {
          const coords = geocodeCache[card.dataset.ville ?? ''];
          if (coords) {
            const dist = haversine(userLat, userLng, coords.lat, coords.lng);
            card.dataset.distanceKm = dist.toFixed(1);
            const badge = card.querySelector<HTMLElement>('.distance-badge');
            if (badge) { badge.textContent = `· ${dist < 1 ? '< 1' : Math.round(dist)} km`; badge.classList.remove('hidden'); }
          } else { card.dataset.distanceKm = '99999'; }
        });
        [...cards].sort((a, b) => parseFloat(a.dataset.distanceKm ?? '99999') - parseFloat(b.dataset.distanceKm ?? '99999')).forEach((c) => grid.appendChild(c));
        geoActive = true;
        btnGeo.classList.remove('text-gray-500');
        btnGeo.classList.add('text-orange-500');
        setGeoLoading(false);
      },
      (err) => { setGeoLoading(false); if (err.code !== err.PERMISSION_DENIED) alert("Impossible d'obtenir votre position."); },
      { timeout: 10000 }
    );
  });
</script>
