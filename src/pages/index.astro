---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.js';

const activites: any[] = sanityClient
  ? await sanityClient.fetch(
      `*[_type == "adherent"] | order(nom asc) { nom, "slug": slug.current, type, publics, saison, description, ville }`
    ).catch(() => [])
  : [];

const types   = [...new Set(activites.map((a) => a.type).filter(Boolean))] as string[];
const publics = [...new Set(activites.flatMap((a) => a.publics ?? []).filter(Boolean))] as string[];
const saisons = [...new Set(activites.map((a) => a.saison).filter(Boolean))] as string[];
const total   = activites.length;
---

<Layout title="Loisirs 66 — Trouver une activité">
  <main class="max-w-6xl mx-auto px-4 py-8">

    <!-- Logo -->
    <div class="flex justify-center mb-6">
      <img src="/logo-aplpo.avif" alt="APLPO — Loisirs 66" class="h-24 w-auto" />
    </div>

    <!-- Bloc recherche -->
    <section class="bg-white border border-gray-100 shadow-sm rounded-2xl p-6 mb-6">
      <p class="text-xs text-gray-400 uppercase tracking-widest mb-4">Trouver une activité</p>

      <input
        id="search-input"
        type="search"
        placeholder="Rechercher (parc, escalade, VR...)"
        autocomplete="off"
        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400 mb-3"
      />

      <div class="flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
          <select id="filter-type" class="w-full appearance-none bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 outline-none focus:border-orange-400 cursor-pointer pr-10">
            <option value="">Tout type</option>
            {types.map((t) => <option value={t}>{t}</option>)}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>

        <div class="relative flex-1">
          <select id="filter-public" class="w-full appearance-none bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 outline-none focus:border-orange-400 cursor-pointer pr-10">
            <option value="">Tout public</option>
            {publics.map((p) => <option value={p}>{p}</option>)}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>

        <div class="relative flex-1">
          <select id="filter-saison" class="w-full appearance-none bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 outline-none focus:border-orange-400 cursor-pointer pr-10">
            <option value="">Toute saison</option>
            {saisons.map((s) => <option value={s}>{s}</option>)}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- Grille de cartes -->
    <div id="cards-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {activites?.map((a) => (
        <a
          href={a.slug ? `/loisirs66/${a.slug}` : '#'}
          class="activity-card bg-white border border-gray-100 shadow-sm rounded-2xl p-5 flex flex-col gap-3 hover:bg-gray-50 transition-colors no-underline"
          data-nom={(a.nom ?? '').toLowerCase()}
          data-description={(a.description ?? '').toLowerCase()}
          data-type={(a.type ?? '').toLowerCase()}
          data-public={(a.publics ?? []).join(',').toLowerCase()}
          data-saison={(a.saison ?? '').toLowerCase()}
        >
          <!-- Tags -->
          <div class="flex gap-2 flex-wrap">
            {a.type && (
              <span class={`text-xs font-medium px-3 py-1 rounded-full ${
                a.type === 'Outdoor'
                  ? 'bg-green-100 text-green-700 border border-green-300'
                  : 'bg-sky-100 text-sky-700 border border-sky-300'
              }`}>
                {a.type}
              </span>
            )}
            {(a.publics ?? []).map((p: string) => (
              <span class="text-xs font-medium px-3 py-1 rounded-full bg-gray-100 text-gray-600">
                {p}
              </span>
            ))}
          </div>

          <!-- Nom -->
          <h2 class="text-xl font-bold text-gray-900 leading-snug">{a.nom}</h2>

          <!-- Description -->
          {a.description && (
            <p class="text-gray-600 text-sm leading-relaxed line-clamp-2">{a.description}</p>
          )}

          <!-- Ville -->
          {a.ville && (
            <p class="text-gray-400 text-sm mt-auto">{a.ville}</p>
          )}
        </a>
      ))}
    </div>

    <!-- Compteur -->
    <p id="count" class="text-right text-gray-400 text-sm mt-4">
      {total} activité{total > 1 ? 's' : ''} trouvée{total > 1 ? 's' : ''}
    </p>

  </main>
</Layout>

<script>
  const searchInput  = document.getElementById('search-input') as HTMLInputElement;
  const filterType   = document.getElementById('filter-type') as HTMLSelectElement;
  const filterPublic = document.getElementById('filter-public') as HTMLSelectElement;
  const filterSaison = document.getElementById('filter-saison') as HTMLSelectElement;
  const cards        = document.querySelectorAll<HTMLElement>('.activity-card');
  const countEl      = document.getElementById('count');

  function applyFilters() {
    const query  = searchInput.value.toLowerCase();
    const type   = filterType.value.toLowerCase();
    const pub    = filterPublic.value.toLowerCase();
    const saison = filterSaison.value.toLowerCase();

    let visible = 0;

    cards.forEach((card) => {
      const matches =
        (!query  || (card.dataset.nom ?? '').includes(query) || (card.dataset.description ?? '').includes(query)) &&
        (!type   || (card.dataset.type   ?? '') === type) &&
        (!pub    || (card.dataset.public ?? '') === pub) &&
        (!saison || (card.dataset.saison ?? '') === saison);

      card.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });

    if (countEl) {
      countEl.textContent = `${visible} activité${visible > 1 ? 's' : ''} trouvée${visible > 1 ? 's' : ''}`;
    }
  }

  searchInput?.addEventListener('input', applyFilters);
  filterType?.addEventListener('change', applyFilters);
  filterPublic?.addEventListener('change', applyFilters);
  filterSaison?.addEventListener('change', applyFilters);
</script>
