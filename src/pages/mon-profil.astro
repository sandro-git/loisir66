---
import Layout from '../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';
import { sanityClient } from '../lib/sanity.js';

// Auth
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) return Astro.redirect('/connexion');

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } }
);

const { data: { user }, error: authError } = await supabase.auth.getUser();
if (authError || !user) return Astro.redirect('/connexion');

// Récupère la fiche liée
const { data: adherentRow } = await supabase
  .from('adherents')
  .select('sanity_doc_id')
  .eq('id', user.id)
  .single();

let fiche: any = null;
if (adherentRow?.sanity_doc_id && sanityClient) {
  fiche = await sanityClient.fetch(
    `*[_type == "adherent" && _id == $id][0]{
      _id, nom, soustitre, type, publics, saison,
      description, ville, adresse, horaires, tarifs, siteWeb
    }`,
    { id: adherentRow.sanity_doc_id.trim() }
  ).catch(() => null);
}

const success = Astro.url.searchParams.get('success');
const erreur  = Astro.url.searchParams.get('erreur');

const typeOptions   = ['Indoor', 'Outdoor'];
const publicOptions = ['Famille', 'Enfants', 'Adultes', 'Tous', 'Team building'];
const saisonOptions = ['Été', 'Hiver', 'Toute saison'];
---

<Layout title="Mon profil — Loisirs 66">
  <main class="max-w-2xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-white">Ma fiche activité</h1>
        <p class="text-gray-500 text-sm">{user.email}</p>
      </div>
      <form method="POST" action="/api/logout">
        <button class="text-gray-500 text-sm hover:text-gray-300 transition-colors">
          Déconnexion
        </button>
      </form>
    </div>

    {success === '1' && (
      <div class="bg-green-950 border border-green-800 text-green-400 text-sm rounded-lg px-4 py-3 mb-6">
        Fiche mise à jour avec succès.
      </div>
    )}

    {erreur === 'no-doc' && (
      <div class="bg-red-950 border border-red-800 text-red-400 text-sm rounded-lg px-4 py-3 mb-6">
        Aucune fiche n'est encore liée à votre compte. Contactez l'administrateur.
      </div>
    )}

    {!adherentRow?.sanity_doc_id ? (
      <div class="bg-[#1c1c1c] rounded-2xl p-8 text-center">
        <p class="text-gray-400">Votre compte n'est pas encore lié à une fiche activité.</p>
        <p class="text-gray-500 text-sm mt-2">Contactez l'administrateur APLPO.</p>
      </div>
    ) : (
      <form method="POST" action="/api/update-profil" class="space-y-6">
        <div class="bg-[#1c1c1c] rounded-2xl p-6 space-y-5">

          <h2 class="text-xs text-gray-500 uppercase tracking-widest">Informations générales</h2>

          <!-- Nom -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Nom de l'activité *</label>
            <input
              name="nom" type="text" required
              value={fiche?.nom ?? ''}
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white outline-none focus:border-gray-500"
            />
          </div>

          <!-- Sous-titre -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Sous-titre</label>
            <input
              name="soustitre" type="text"
              value={fiche?.soustitre ?? ''}
              placeholder="Ex : Salle de réalité virtuelle"
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white placeholder-gray-600 outline-none focus:border-gray-500"
            />
          </div>

          <!-- Type -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Type</label>
            <select
              name="type"
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white outline-none focus:border-gray-500"
            >
              <option value="">— Choisir —</option>
              {typeOptions.map(t => (
                <option value={t} selected={fiche?.type === t}>{t}</option>
              ))}
            </select>
          </div>

          <!-- Public (cases à cocher) -->
          <div>
            <label class="block text-sm text-gray-400 mb-3">Public(s)</label>
            <div class="flex flex-wrap gap-3">
              {publicOptions.map(p => (
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    name="publics"
                    value={p}
                    checked={(fiche?.publics ?? []).includes(p)}
                    class="accent-blue-500"
                  />
                  <span class="text-sm text-gray-300">{p}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Saison -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Saison</label>
            <select
              name="saison"
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white outline-none focus:border-gray-500"
            >
              <option value="">— Choisir —</option>
              {saisonOptions.map(s => (
                <option value={s} selected={fiche?.saison === s}>{s}</option>
              ))}
            </select>
          </div>

          <!-- Description -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Description</label>
            <textarea
              name="description"
              rows={4}
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white placeholder-gray-600 outline-none focus:border-gray-500 resize-none"
            >{fiche?.description ?? ''}</textarea>
          </div>
        </div>

        <div class="bg-[#1c1c1c] rounded-2xl p-6 space-y-5">
          <h2 class="text-xs text-gray-500 uppercase tracking-widest">Infos pratiques</h2>

          <!-- Ville -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Ville</label>
            <input
              name="ville" type="text"
              value={fiche?.ville ?? ''}
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white outline-none focus:border-gray-500"
            />
          </div>

          <!-- Adresse -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Adresse</label>
            <input
              name="adresse" type="text"
              value={fiche?.adresse ?? ''}
              placeholder="Ex : 10 rue des Lilas, 66000"
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white placeholder-gray-600 outline-none focus:border-gray-500"
            />
          </div>

          <!-- Horaires -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Horaires</label>
            <input
              name="horaires" type="text"
              value={fiche?.horaires ?? ''}
              placeholder="Ex : Mar–Dim, 10h–20h"
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white placeholder-gray-600 outline-none focus:border-gray-500"
            />
          </div>

          <!-- Tarifs -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Tarifs</label>
            <input
              name="tarifs" type="text"
              value={fiche?.tarifs ?? ''}
              placeholder="Ex : Dès 15€ / séance"
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white placeholder-gray-600 outline-none focus:border-gray-500"
            />
          </div>

          <!-- Site web -->
          <div>
            <label class="block text-sm text-gray-400 mb-2">Site web</label>
            <input
              name="siteWeb" type="url"
              value={fiche?.siteWeb ?? ''}
              placeholder="https://..."
              class="w-full bg-[#111] border border-[#2e2e2e] rounded-lg px-4 py-3 text-white placeholder-gray-600 outline-none focus:border-gray-500"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 rounded-xl transition-colors"
        >
          Enregistrer les modifications
        </button>

        <a href="/" class="block text-center text-gray-500 text-sm hover:text-gray-300 transition-colors">
          ← Retour aux activités
        </a>
      </form>
    )}
  </main>
</Layout>
