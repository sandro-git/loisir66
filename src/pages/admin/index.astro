---
import Layout from '../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';
import { sanityClient } from '../../lib/sanity.js';

const ADMIN_EMAIL = 'sandro@vr-cafe.fr';

// Protection admin
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) return Astro.redirect('/connexion');

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } }
);

const { data: { user }, error } = await supabase.auth.getUser();
if (error || !user || user.email !== ADMIN_EMAIL) return Astro.redirect('/connexion');

// Membres Sanity sans compte Supabase
const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
  { auth: { autoRefreshToken: false, persistSession: false } }
);

const tousAdherents: { _id: string; nom: string }[] = sanityClient
  ? await sanityClient.fetch(`*[_type == "adherent"] | order(nom asc) { _id, nom }`).catch(() => [])
  : [];

const { data: comptes } = await supabaseAdmin.from('adherents').select('sanity_doc_id');
const avecCompte = new Set((comptes ?? []).map((r: any) => r.sanity_doc_id));
const sansCompte = tousAdherents.filter(a => !avecCompte.has(a._id));

// Lecture des paramètres de retour
const success     = Astro.url.searchParams.get('success');
const mdp         = Astro.url.searchParams.get('mdp');
const nom         = Astro.url.searchParams.get('nom');
const email       = Astro.url.searchParams.get('email');
const erreur      = Astro.url.searchParams.get('erreur');

const erreurMsg: Record<string, string> = {
  'champs-manquants':  'Tous les champs sont obligatoires.',
  'email-existant':    'Un compte existe déjà avec cet email.',
  'sanity':            'Erreur lors de la création de la fiche Sanity.',
  'table':             'Erreur lors de la liaison du compte.',
  'fiche-introuvable': 'Fiche Sanity introuvable.',
};
---

<Layout title="Admin — Membres">
  <main class="max-w-lg mx-auto px-4 py-16">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Gestion des membres</h1>
      <a href="/" class="text-sm text-gray-500 hover:text-orange-500 transition-colors">← Retour au site</a>
    </div>

    <!-- Succès -->
    {success && mdp && (
      <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-6">
        <p class="text-green-700 font-semibold mb-3">✓ Compte créé avec succès</p>
        <div class="space-y-1 text-sm text-green-700">
          <p><span class="text-green-600">Nom :</span> {nom}</p>
          <p><span class="text-green-600">Email :</span> {email}</p>
          <p class="mt-3">
            <span class="text-green-600">Mot de passe temporaire :</span>
            <span class="font-mono bg-green-100 px-3 py-1 rounded-lg ml-2 text-green-900 text-base">{mdp}</span>
          </p>
        </div>
        <p class="text-green-500 text-xs mt-4">Transmets ces identifiants au membre de façon sécurisée.</p>
      </div>
    )}

    <!-- Erreur -->
    {erreur && (
      <div class="bg-red-50 border border-red-200 text-red-600 text-sm rounded-2xl px-5 py-4 mb-6">
        {erreurMsg[erreur] ?? 'Une erreur est survenue.'}
      </div>
    )}

    <!-- Section 1 : Nouveau membre (fiche + compte) -->
    <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-8 mb-6">
      <h2 class="text-gray-900 font-semibold mb-1">Nouveau membre</h2>
      <p class="text-gray-500 text-sm mb-5">Crée une fiche Sanity et un compte de connexion.</p>
      <form method="POST" action="/api/admin/add-membre" class="space-y-5">
        <div>
          <label class="block text-sm text-gray-600 mb-2" for="nom">Nom commercial</label>
          <input
            id="nom" name="nom" type="text" required
            placeholder="Ex : EVA Perpignan"
            class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400"
          />
        </div>
        <div>
          <label class="block text-sm text-gray-600 mb-2" for="email">Email</label>
          <input
            id="email" name="email" type="email" required
            placeholder="contact@exemple.fr"
            class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400"
          />
        </div>
        <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 rounded-xl transition-colors">
          Créer le membre
        </button>
      </form>
    </div>

    <!-- Section 2 : Créer un compte pour une fiche existante -->
    {sansCompte.length > 0 && (
      <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-8">
        <h2 class="text-gray-900 font-semibold mb-1">Créer un accès pour une fiche existante</h2>
        <p class="text-gray-500 text-sm mb-5">
          {sansCompte.length} fiche{sansCompte.length > 1 ? 's' : ''} sans compte de connexion.
        </p>
        <form method="POST" action="/api/admin/add-compte" class="space-y-5">
          <div>
            <label class="block text-sm text-gray-600 mb-2" for="sanity_doc_id">Membre</label>
            <div class="relative">
              <select
                id="sanity_doc_id" name="sanity_doc_id" required
                class="w-full appearance-none bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 outline-none focus:border-orange-400 cursor-pointer pr-10"
              >
                <option value="">Choisir un membre…</option>
                {sansCompte.map(a => (
                  <option value={a._id}>{a.nom}</option>
                ))}
              </select>
              <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-2" for="email2">Email</label>
            <input
              id="email2" name="email" type="email" required
              placeholder="contact@exemple.fr"
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 outline-none focus:border-orange-400"
            />
          </div>
          <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 rounded-xl transition-colors">
            Créer le compte
          </button>
        </form>
      </div>
    )}

    {sansCompte.length === 0 && (
      <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-6 text-center text-gray-400 text-sm">
        Tous les membres ont un compte de connexion.
      </div>
    )}

  </main>
</Layout>
