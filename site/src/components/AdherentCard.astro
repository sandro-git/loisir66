---
interface Props {
  nom: string;
  type?: string;       // Indoor | Outdoor
  public?: string;     // Famille | Enfants | Adultes
  description?: string;
  ville?: string;
  slug?: string;
  // compat legacy
  activite?: string;
  image?: string;
}

const { nom, type, public: pub, description, ville, slug, activite, image } = Astro.props;
---

<a
  href={slug ? `/loisirs66/${slug}` : '#'}
  class="bg-[#1c1c1c] rounded-2xl p-5 flex flex-col gap-3 hover:bg-[#222222] transition-colors no-underline"
>
  <!-- Tags -->
  <div class="flex gap-2 flex-wrap">
    {type && (
      <span class={`text-xs font-medium px-3 py-1 rounded-full ${
        type === 'Outdoor'
          ? 'bg-green-950 text-green-400 border border-green-800'
          : 'bg-blue-950 text-blue-400 border border-blue-800'
      }`}>
        {type}
      </span>
    )}
    {pub && (
      <span class="text-xs font-medium px-3 py-1 rounded-full bg-[#2a2a2a] text-gray-300">
        {pub}
      </span>
    )}
  </div>

  {image && <img src={image} alt={nom} class="w-full rounded-lg object-cover h-40" />}

  <h2 class="text-xl font-bold text-white leading-snug">{nom}</h2>

  {(description ?? activite) && (
    <p class="text-gray-400 text-sm leading-relaxed line-clamp-2">{description ?? activite}</p>
  )}

  {ville && <p class="text-gray-500 text-sm mt-auto">{ville}</p>}
</a>
